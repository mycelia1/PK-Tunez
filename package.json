{
  "name": "pk-tunez",
  "version": "1.0.4",
  "description": "PK-Tunez — EarthBound-style SoundCloud downloader UI",
  "main": "./out/main/index.js",
  "author": {
    "name": "PK-Tunez"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/copy-resources.mjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "bundle:binaries:win": "powershell -ExecutionPolicy Bypass -File scripts/bundle-binaries/bundle-win.ps1",
    "bundle:binaries:mac": "bash scripts/bundle-binaries/bundle-mac.sh",
    "build:win": "npm run build && electron-builder --win --publish never --config electron-builder.yml",
    "build:mac": "npm run build && electron-builder --mac --publish never --config electron-builder.yml",
    "build:unpack": "npm run build && electron-builder --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.5",
    "@fontsource/vt323": "^5.2.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
